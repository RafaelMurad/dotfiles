# Functions

# ── mkcd — create directory and cd into it ──────────────
mkcd() {
  mkdir -p "$1" && cd "$1"
}

# ── serve — start a local HTTP server ───────────────────
serve() {
  local port="${1:-8000}"
  echo "Serving on http://localhost:$port"
  python3 -m http.server "$port"
}

# ── port — show what's running on a port ────────────────
port() {
  if [[ -z "$1" ]]; then
    echo "Usage: port <number>"
    return 1
  fi
  lsof -i :"$1"
}

# ── killport — kill process on a port ───────────────────
killport() {
  if [[ -z "$1" ]]; then
    echo "Usage: killport <number>"
    return 1
  fi
  local pid
  pid=$(lsof -ti :"$1" 2>/dev/null)
  if [[ -n "$pid" ]]; then
    kill -9 "$pid"
    echo "Killed process $pid on port $1"
  else
    echo "No process found on port $1"
  fi
}

# ── gopen — open current repo in browser ────────────────
gopen() {
  local url
  url=$(git remote get-url origin 2>/dev/null)
  if [[ -z "$url" ]]; then
    echo "Not a git repository or no remote 'origin'"
    return 1
  fi
  # Convert SSH URL to HTTPS
  url="${url/git@github.com:/https://github.com/}"
  url="${url%.git}"
  open "$url"
}

# ── extract — universal archive extractor ───────────────
extract() {
  if [[ -z "$1" ]]; then
    echo "Usage: extract <file>"
    return 1
  fi
  if [[ ! -f "$1" ]]; then
    echo "'$1' is not a file"
    return 1
  fi
  case "$1" in
    *.tar.bz2) tar xjf "$1"   ;;
    *.tar.gz)  tar xzf "$1"   ;;
    *.tar.xz)  tar xJf "$1"   ;;
    *.bz2)     bunzip2 "$1"   ;;
    *.gz)      gunzip "$1"    ;;
    *.tar)     tar xf "$1"    ;;
    *.tbz2)    tar xjf "$1"   ;;
    *.tgz)     tar xzf "$1"   ;;
    *.zip)     unzip "$1"     ;;
    *.Z)       uncompress "$1" ;;
    *.7z)      7z x "$1"      ;;
    *.rar)     unrar x "$1"   ;;
    *)         echo "Cannot extract '$1'" ; return 1 ;;
  esac
}

# ── tre — tree with sensible defaults ───────────────────
tre() {
  tree -aC -I '.git|node_modules|.next|dist|build|coverage|.turbo' \
    --dirsfirst "${@:-.}" | less -FRNX
}

# ── fs — file/directory size ────────────────────────────
fs() {
  if du -b /dev/null > /dev/null 2>&1; then
    du -sbh "${@:-.}"
  else
    du -sh "${@:-.}"
  fi
}

# ── gz — compare original and gzipped size ──────────────
gz() {
  local origsize gzipsize ratio
  origsize=$(wc -c < "$1")
  gzipsize=$(gzip -c "$1" | wc -c)
  ratio=$(echo "$gzipsize * 100 / $origsize" | bc -l)
  printf "orig: %d bytes\ngzip: %d bytes\nratio: %.2f%%\n" "$origsize" "$gzipsize" "$ratio"
}
