#!/usr/bin/env zsh
set -e

# Capture script path at top level (zsh $0 inside functions returns the function name)
_SCRIPT_PATH="$0"

# ── Remote bootstrap ───────────────────────────────────
# Supports: curl -fsSL https://raw.githubusercontent.com/RafaelMurad/dotfiles/main/setup | zsh
# Wrapped in a function so the entire script is downloaded before execution
_setup() {

if [[ ! -d "$HOME/dotfiles/.git" ]]; then
  echo "Cloning dotfiles..."
  git clone https://github.com/RafaelMurad/dotfiles.git "$HOME/dotfiles"
  exec "$HOME/dotfiles/setup" < /dev/tty
fi

# Restore TTY if stdin was piped (e.g. curl | zsh)
[[ ! -t 0 ]] && exec < /dev/tty

DOTFILES_DIR="$(cd "$(dirname "$_SCRIPT_PATH")" && pwd)"

# Colors
bold="\033[1m"
dim="\033[2m"
green="\033[32m"
blue="\033[34m"
yellow="\033[33m"
red="\033[31m"
reset="\033[0m"

step()  { echo "\n${bold}${blue}[$1]${reset} ${bold}$2${reset}" }
ok()    { echo "  ${green}✓${reset} $1" }
skip()  { echo "  ${dim}· $1 (already done)${reset}" }
info()  { echo "  ${yellow}→${reset} $1" }
fail()  { echo "  ${red}✗${reset} $1"; exit 1 }

# ── Helper ──────────────────────────────────────────────
link_file() {
  local src="$1" dest="$2"
  if [[ -L "$dest" ]]; then
    rm "$dest"
  elif [[ -f "$dest" ]]; then
    mv "$dest" "${dest}.bak"
    info "Backed up $(basename "$dest")"
  fi
  ln -sf "$src" "$dest"
  ok "$(basename "$dest")"
}

echo ""
echo "${bold}  Rafael's Dev Environment${reset}"
echo "${dim}  github.com/RafaelMurad/dotfiles${reset}"
echo ""

# ── 1. Homebrew ─────────────────────────────────────────
step 1 "Homebrew"
if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  [[ -f /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"
  ok "Installed"
else
  brew update --quiet
  skip "Homebrew"
fi

# ── 2. Packages ─────────────────────────────────────────
step 2 "Brewfile (packages, apps, extensions)"
if brew bundle check --file="$DOTFILES_DIR/Brewfile" &>/dev/null; then
  skip "Brewfile"
else
  brew bundle --file="$DOTFILES_DIR/Brewfile" --quiet
  ok "All packages installed"
fi

# ── 3. Volta + Node ─────────────────────────────────────
step 3 "Volta + Node"
if ! command -v volta &>/dev/null; then
  curl -sSf https://get.volta.sh | bash -s -- --skip-setup
  export VOLTA_HOME="$HOME/.volta"
  export PATH="$VOLTA_HOME/bin:$PATH"
  ok "Volta installed"
else
  skip "Volta"
fi

volta install node@lts 2>/dev/null
ok "Node LTS"

for pkg in pnpm yarn vercel playwright-mcp confluence-cli; do
  volta install "$pkg" 2>/dev/null
  ok "$pkg"
done

# ── 4. Oh My Zsh ────────────────────────────────────────
step 4 "Oh My Zsh"
if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
  ok "Installed"
else
  skip "Oh My Zsh"
fi

# Install custom plugins if missing
ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

if [[ ! -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ]]; then
  git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
  ok "zsh-autosuggestions"
else
  skip "zsh-autosuggestions"
fi

if [[ ! -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ]]; then
  git clone --depth=1 https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"
  ok "zsh-syntax-highlighting"
else
  skip "zsh-syntax-highlighting"
fi

# ── 5. Dotfiles ─────────────────────────────────────────
step 5 "Symlink dotfiles"

link_file "$DOTFILES_DIR/.zshrc"      "$HOME/.zshrc"
link_file "$DOTFILES_DIR/.zprofile"   "$HOME/.zprofile"
link_file "$DOTFILES_DIR/.zshenv"     "$HOME/.zshenv"
link_file "$DOTFILES_DIR/.gitconfig"  "$HOME/.gitconfig"
link_file "$DOTFILES_DIR/.aliases"    "$HOME/.aliases"
link_file "$DOTFILES_DIR/.functions"  "$HOME/.functions"

link_file "$DOTFILES_DIR/.gitignore_global" "$HOME/.gitignore_global"

link_file "$DOTFILES_DIR/.editorconfig" "$HOME/.editorconfig"

mkdir -p "$HOME/.ssh/config.d" && chmod 700 "$HOME/.ssh"
link_file "$DOTFILES_DIR/.ssh/config" "$HOME/.ssh/config"

mkdir -p "$HOME/.config/gh"
link_file "$DOTFILES_DIR/gh/config.yml" "$HOME/.config/gh/config.yml"

mkdir -p "$HOME/.config/ghostty"
link_file "$DOTFILES_DIR/ghostty/config" "$HOME/.config/ghostty/config"

# ── 6. Editor settings ──────────────────────────────────
step 6 "Editor settings"

VSCODE_USER="$HOME/Library/Application Support/Code/User"
mkdir -p "$VSCODE_USER"
link_file "$DOTFILES_DIR/vscode/settings.json"    "$VSCODE_USER/settings.json"
link_file "$DOTFILES_DIR/vscode/keybindings.json"  "$VSCODE_USER/keybindings.json"

CURSOR_USER="$HOME/Library/Application Support/Cursor/User"
mkdir -p "$CURSOR_USER"
link_file "$DOTFILES_DIR/cursor/settings.json"     "$CURSOR_USER/settings.json"

# ── 7. GitHub CLI ────────────────────────────────────────
step 7 "GitHub CLI auth"
if gh auth status &>/dev/null 2>&1; then
  skip "GitHub CLI"
else
  info "Authenticate your personal GitHub account:"
  gh auth login
  ok "Authenticated"
fi

# ── 8. SSH key ──────────────────────────────────────────
step 8 "SSH key"
if [[ ! -f "$HOME/.ssh/id_ed25519" ]]; then
  ssh-keygen -t ed25519 -C "rflmurad@gmail.com" -f "$HOME/.ssh/id_ed25519" -N ""
  ok "Generated"

  # Upload to GitHub if gh is authenticated
  if gh auth status &>/dev/null 2>&1; then
    gh ssh-key add "$HOME/.ssh/id_ed25519.pub" --title "$(scutil --get ComputerName 2>/dev/null || hostname)"
    ok "Added to GitHub"
  else
    if command -v pbcopy &>/dev/null; then
      pbcopy < "$HOME/.ssh/id_ed25519.pub"
      info "Public key copied to clipboard"
    fi
    info "Add it to https://github.com/settings/keys"
  fi
else
  skip "SSH key"
fi

# ── 9. macOS defaults ───────────────────────────────────
step 9 "macOS defaults"
_did_macos=false

# Detect if our defaults have already been applied (check a few distinctive ones)
_macos_applied=false
if [[ "$(defaults read com.apple.dock autohide 2>/dev/null)" == "1" ]] \
  && [[ "$(defaults read com.apple.dock tilesize 2>/dev/null)" == "48" ]] \
  && [[ "$(defaults read NSGlobalDomain ApplePressAndHoldEnabled 2>/dev/null)" == "0" ]]; then
  _macos_applied=true
fi

if $_macos_applied; then
  skip "macOS defaults"
  _did_macos=true
else
  echo ""
  read -q "REPLY?  Apply macOS system preferences? (y/n) " || true
  echo ""
  if [[ "$REPLY" == "y" ]]; then
    "$DOTFILES_DIR/.macos"
    _did_macos=true
  else
    info "Skipped — run ${bold}./.macos${reset} anytime"
  fi
fi

# ── 10. Work profile ────────────────────────────────────
step 10 "Work profile"
_did_work=false

# Detect if a work profile already exists
if [[ -f "$HOME/.gitconfig-work" ]]; then
  _work_email=$(git config -f "$HOME/.gitconfig-work" user.email 2>/dev/null)
  _work_name=$(git config -f "$HOME/.gitconfig-work" user.name 2>/dev/null)
  skip "Work profile ($_work_name <$_work_email>)"
  _did_work=true

  echo ""
  read -q "REPLY?  Reconfigure work profile? (y/n) " || true
  echo ""
  if [[ "$REPLY" == "y" ]]; then
    "$DOTFILES_DIR/setup-work-profile"
  fi
else
  echo ""
  read -q "REPLY?  Set up a work profile now? (y/n) " || true
  echo ""
  if [[ "$REPLY" == "y" ]]; then
    "$DOTFILES_DIR/setup-work-profile"
    _did_work=true
  else
    info "Skipped — run ${bold}./setup-work-profile${reset} anytime"
  fi
fi

# ── Done ─────────────────────────────────────────────────
echo ""
echo "${green}${bold}  Setup complete!${reset}"
echo ""

# ── What was installed ──────────────────────────────────
echo "${bold}  Tools & Runtimes${reset}"
echo "  ${dim}─────────────────────────────────────────${reset}"
echo "  ${green}✓${reset} Homebrew        $(brew --version 2>/dev/null | head -1 | cut -d' ' -f2)"
echo "  ${green}✓${reset} Git             $(git --version 2>/dev/null | cut -d' ' -f3)"
echo "  ${green}✓${reset} Volta           $(volta --version 2>/dev/null || echo 'n/a')"
echo "  ${green}✓${reset} Node            $(node --version 2>/dev/null || echo 'n/a')"
echo "  ${green}✓${reset} pnpm            $(pnpm --version 2>/dev/null || echo 'n/a')"
echo "  ${green}✓${reset} yarn            $(yarn --version 2>/dev/null || echo 'n/a')"
echo "  ${green}✓${reset} Oh My Zsh       $([ -d "$HOME/.oh-my-zsh" ] && echo "installed" || echo "missing")"
echo ""

echo "${bold}  CLIs${reset}"
echo "  ${dim}─────────────────────────────────────────${reset}"
echo "  ${green}✓${reset} gh              $(gh --version 2>/dev/null | head -1 | cut -d' ' -f3)          ${dim}GitHub${reset}"
echo "  ${green}✓${reset} vercel          $(vercel --version 2>/dev/null | head -1 | tr -d ' ')   ${dim}Deployments${reset}"
echo "  ${green}✓${reset} opencode        $(opencode --version 2>/dev/null | head -1 || echo 'n/a')          ${dim}AI coding agent${reset}"
echo "  ${green}✓${reset} ollama          $(ollama --version 2>&1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo 'n/a')          ${dim}Local LLMs${reset}"
echo "  ${green}✓${reset} fzf             $(fzf --version 2>/dev/null | awk '{print $1}')          ${dim}Fuzzy finder${reset}"
echo "  ${green}✓${reset} ripgrep         $(rg --version 2>/dev/null | head -1 | awk '{print $2}' || echo 'n/a')          ${dim}Fast search${reset}"
echo "  ${green}✓${reset} bat             $(bat --version 2>/dev/null | awk '{print $2}' || echo 'n/a')          ${dim}Better cat${reset}"
echo "  ${green}✓${reset} eza             $(eza --version 2>/dev/null | head -1 | awk '{print $2}' || echo 'n/a')          ${dim}Modern ls${reset}"
echo "  ${green}✓${reset} fd              $(fd --version 2>/dev/null | awk '{print $2}' || echo 'n/a')          ${dim}Better find${reset}"
echo "  ${green}✓${reset} jq              $(jq --version 2>/dev/null | tr -d 'jq-' || echo 'n/a')          ${dim}JSON processor${reset}"
echo "  ${green}✓${reset} delta           $(delta --version 2>/dev/null | awk '{print $2}' || echo 'n/a')          ${dim}Better diffs${reset}"
echo "  ${green}✓${reset} zoxide          $(zoxide --version 2>/dev/null | awk '{print $2}' || echo 'n/a')          ${dim}Smarter cd${reset}"
echo "  ${green}✓${reset} btop            $(btop --version 2>/dev/null | head -1 | sed 's/\x1b\[[0-9;]*m//g' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || echo 'n/a')          ${dim}System monitor${reset}"
echo "  ${green}✓${reset} tree            $(tree --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || echo 'n/a')          ${dim}Directory tree${reset}"
echo "  ${green}✓${reset} shellcheck      $(shellcheck --version 2>/dev/null | grep version: | awk '{print $2}' || echo 'n/a')          ${dim}Shell linter${reset}"
echo ""

echo "${bold}  Apps${reset}"
echo "  ${dim}─────────────────────────────────────────${reset}"
echo "  ${green}✓${reset} Ghostty                          ${dim}Terminal${reset}"
echo "  ${green}✓${reset} VS Code                          ${dim}Editor${reset}"
echo "  ${green}✓${reset} Cursor                           ${dim}AI editor${reset}"
echo "  ${green}✓${reset} Claude Code                      ${dim}AI terminal${reset}"
echo "  ${green}✓${reset} Figma                            ${dim}Design${reset}"
echo "  ${green}✓${reset} Spotify                          ${dim}Music${reset}"
echo "  ${green}✓${reset} Google Cloud SDK                  ${dim}gcloud, gsutil, bq${reset}"
echo ""

echo "${bold}  Configs${reset}"
echo "  ${dim}─────────────────────────────────────────${reset}"
echo "  ${green}✓${reset} Shell           .zshrc, .zprofile, .zshenv, .aliases, .functions"
echo "  ${green}✓${reset} Git             .gitconfig, .gitignore_global, .editorconfig"
echo "  ${green}✓${reset} SSH             ~/.ssh/config"
echo "  ${green}✓${reset} VS Code         settings.json, keybindings.json, ${dim}$(brew list --vscode 2>/dev/null | wc -l | tr -d ' ' || echo '25') extensions${reset}"
echo "  ${green}✓${reset} Cursor          settings.json"
echo "  ${green}✓${reset} GitHub CLI      config.yml"
echo "  ${green}✓${reset} Ghostty         ~/.config/ghostty/config"
if [[ "$_did_macos" == "true" ]]; then
  echo "  ${green}✓${reset} macOS           system preferences applied"
fi
echo ""

# ── Try it out ──────────────────────────────────────────
_n=1
echo "${bold}  Try it out${reset}"
echo "  ${dim}─────────────────────────────────────────${reset}"
echo "  ${yellow}$_n${reset}  Open Ghostty (your new terminal)"
echo "     ${dim}# it's in your Dock — all settings carry over${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  Fuzzy-find a file"
echo "     ${dim}fzf${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  Monitor your system"
echo "     ${dim}btop${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  Check your Git identity"
echo "     ${dim}git config user.name && git config user.email${reset}"
echo "     ${dim}# Rafael Murad <rflmurad@gmail.com>${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  Test GitHub SSH"
echo "     ${dim}ssh -T git@github.com${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  Check GitHub CLI auth"
echo "     ${dim}gh auth status${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  Verify all Homebrew packages"
echo "     ${dim}brew bundle check --file=~/dotfiles/Brewfile${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  List Node, pnpm, yarn versions"
echo "     ${dim}volta list all${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  Run an AI coding session"
echo "     ${dim}opencode${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  Try your shell aliases"
echo "     ${dim}ll              # detailed listing${reset}"
echo "     ${dim}gs              # git status${reset}"
echo "     ${dim}glog            # pretty git log${reset}"
echo "     ${dim}myip            # your public IP${reset}"
echo "     ${dim}path            # list PATH entries${reset}"; ((_n++))
echo ""
echo "  ${yellow}$_n${reset}  Try your shell functions"
echo "     ${dim}mkcd test-dir   # mkdir + cd${reset}"
echo "     ${dim}serve           # local HTTP server${reset}"
echo "     ${dim}port 3000       # what's on port 3000?${reset}"; ((_n++))
echo ""

# ── Next steps ──────────────────────────────────────────
_next=1
echo "${bold}  Next steps${reset}"
echo "  ${dim}─────────────────────────────────────────${reset}"
echo "  ${yellow}$_next${reset}  Restart your shell           ${dim}exec zsh${reset}"; ((_next++))
echo "  ${yellow}$_next${reset}  Clone your repos             ${dim}~/dotfiles/clone-repos${reset}"; ((_next++))
if [[ "$_did_work" == "false" ]]; then
  echo "  ${yellow}$_next${reset}  Set up a work profile        ${dim}~/dotfiles/setup-work-profile${reset}"; ((_next++))
fi
if [[ "$_did_macos" == "false" ]]; then
  echo "  ${yellow}$_next${reset}  Apply macOS defaults         ${dim}~/dotfiles/.macos${reset}"; ((_next++))
fi
echo "  ${yellow}$_next${reset}  Update everything later       ${dim}dot${reset}"
echo ""

# ── Manage ──────────────────────────────────────────────
echo "${bold}  Manage${reset}"
echo "  ${dim}─────────────────────────────────────────${reset}"
echo "  Update everything      ${dim}dot${reset}"
echo "  Update + macOS prefs   ${dim}dot --macos${reset}"
echo "  Work profile wizard    ${dim}~/dotfiles/setup-work-profile${reset}"
echo "  Undo everything        ${dim}~/dotfiles/teardown${reset}"
echo "  Edit your extras       ${dim}\$EDITOR ~/.extra${reset}"
echo ""

} # end _setup
_setup "$@"
