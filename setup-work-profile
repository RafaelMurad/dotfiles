#!/usr/bin/env zsh
# Run standalone anytime: ./setup-work-profile

DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd)"

# Colors
bold="\033[1m"
dim="\033[2m"
green="\033[32m"
blue="\033[34m"
yellow="\033[33m"
red="\033[31m"
reset="\033[0m"

ok()   { echo "  ${green}✓${reset} $1" }
info() { echo "  ${yellow}→${reset} $1" }
ask()  { echo -n "  ${blue}?${reset} $1" }

echo ""
echo "${bold}  Work Profile Setup${reset}"
echo "${dim}  Separate identity for work repos${reset}"
echo ""

# ── 1. Identity ─────────────────────────────────────────
echo "${bold}  Identity${reset}"

DEFAULT_NAME=$(git config --global user.name 2>/dev/null || echo "Rafael Murad")

ask "Full name [$DEFAULT_NAME]: "
read work_name
work_name="${work_name:-$DEFAULT_NAME}"

ask "Work email (required): "
read work_email
[[ -z "$work_email" ]] && echo "\n  ${red}✗${reset} Email is required." && exit 1

ask "Work projects directory [~/work]: "
read work_dir
work_dir="${work_dir:-$HOME/work}"
work_dir="${work_dir/#\~/$HOME}"

mkdir -p "$work_dir"
echo ""
ok "$work_name <$work_email>"
ok "Projects: $work_dir"
echo ""

# ── 2. SSH key ───────────────────────────────────────────
echo "${bold}  SSH Key${reset}"

WORK_KEY="$HOME/.ssh/id_ed25519_work"
_key_resolved=false

# Case A: work key already exists at the expected path
if [[ -f "$WORK_KEY" ]]; then
  info "Work key already exists at $WORK_KEY"
  read -q "REPLY?  Regenerate? (y/n) " || true
  echo ""
  if [[ "$REPLY" == "y" ]]; then
    rm -f "$WORK_KEY" "${WORK_KEY}.pub"
  else
    ok "Keeping existing key"
    _key_resolved=true
  fi
fi

# Case B: no work key yet — look for other existing keys the user might want to reuse
if [[ "$_key_resolved" != "true" && ! -f "$WORK_KEY" ]]; then
  _existing_keys=()
  for _kf in "$HOME"/.ssh/id_*(N); do
    [[ "$_kf" == *.pub ]] && continue
    _existing_keys+=("$_kf")
  done

  if (( ${#_existing_keys[@]} > 0 )); then
    echo ""
    info "Found existing SSH keys:"
    for _i in {1..${#_existing_keys[@]}}; do
      _kf="${_existing_keys[$_i]}"
      _comment=$(ssh-keygen -lf "$_kf" 2>/dev/null | awk '{print $3}')
      echo "    ${yellow}$_i${reset}  ${_kf/#$HOME/~}  ${dim}$_comment${reset}"
    done
    echo "    ${yellow}g${reset}  Generate a new key"
    echo "    ${yellow}s${reset}  Skip"
    echo ""
    ask "Choose [g]: "
    read _choice
    _choice="${_choice:-g}"

    if [[ "$_choice" == "s" ]]; then
      info "Skipped"
      _key_resolved=true
    elif [[ "$_choice" =~ ^[0-9]+$ ]] && (( _choice >= 1 && _choice <= ${#_existing_keys[@]} )); then
      WORK_KEY="${_existing_keys[$_choice]}"
      ok "Using existing key: ${WORK_KEY/#$HOME/~}"
      _key_resolved=true
    fi
    # else: fall through to generate
  fi
fi

# Case C: generate a new work key
if [[ "$_key_resolved" != "true" ]]; then
  ssh-keygen -t ed25519 -C "$work_email" -f "$WORK_KEY" -N ""
  if command -v pbcopy &>/dev/null; then
    pbcopy < "${WORK_KEY}.pub"
    ok "Key generated — public key copied to clipboard"
  else
    ok "Key generated"
    info "$(cat "${WORK_KEY}.pub")"
  fi
  info "Add this key to your work Git host, then press Enter"
  read -s
fi
echo ""

# ── 3. Git host ─────────────────────────────────────────
echo "${bold}  Git Host${reset}"

echo ""
echo "    ${yellow}1${reset}  GitHub (github.com)"
echo "    ${yellow}2${reset}  GitHub Enterprise (self-hosted)"
echo "    ${yellow}3${reset}  GitLab (gitlab.com)"
echo "    ${yellow}4${reset}  GitLab Self-Managed"
echo "    ${yellow}5${reset}  Bitbucket"
echo "    ${yellow}6${reset}  Other"
echo ""
ask "Git provider [1]: "
read _provider_choice
_provider_choice="${_provider_choice:-1}"

case "$_provider_choice" in
  1)
    work_host="github.com"
    _provider="github"
    ;;
  2)
    ask "GitHub Enterprise hostname: "
    read work_host
    [[ -z "$work_host" ]] && echo "\n  ${red}✗${reset} Hostname is required." && exit 1
    _provider="github-enterprise"
    ;;
  3)
    work_host="gitlab.com"
    _provider="gitlab"
    ;;
  4)
    ask "GitLab hostname: "
    read work_host
    [[ -z "$work_host" ]] && echo "\n  ${red}✗${reset} Hostname is required." && exit 1
    _provider="gitlab"
    ;;
  5)
    ask "Bitbucket hostname [bitbucket.org]: "
    read work_host
    work_host="${work_host:-bitbucket.org}"
    _provider="bitbucket"
    ;;
  *)
    ask "Git hostname: "
    read work_host
    [[ -z "$work_host" ]] && echo "\n  ${red}✗${reset} Hostname is required." && exit 1
    _provider="other"
    ;;
esac

ok "Provider: $_provider ($work_host)"

SSH_CONFIG="$HOME/.ssh/config"

# github.com needs an alias since personal already uses it
if [[ "$work_host" == "github.com" ]]; then
  SSH_HOST_ALIAS="github.com-work"

  if grep -q "Host $SSH_HOST_ALIAS" "$SSH_CONFIG" 2>/dev/null; then
    ok "SSH alias '$SSH_HOST_ALIAS' already configured"
  else
    cat >> "$SSH_CONFIG" << EOF

# Work profile (github.com via alias)
Host $SSH_HOST_ALIAS
  HostName github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile $WORK_KEY
EOF
    ok "SSH alias '$SSH_HOST_ALIAS' added"
    info "Clone work repos as: git@github.com-work:org/repo.git"
  fi
else
  if grep -q "Host $work_host" "$SSH_CONFIG" 2>/dev/null; then
    ok "Host '$work_host' already configured"
  else
    ssh-keyscan -H "$work_host" >> "$HOME/.ssh/known_hosts" 2>/dev/null || true
    cat >> "$SSH_CONFIG" << EOF

# Work profile
Host $work_host
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile $WORK_KEY
EOF
    ok "Host '$work_host' added"
  fi
fi
echo ""

# ── 4. Git config ────────────────────────────────────────
echo "${bold}  Git Config${reset}"

cat > "$HOME/.gitconfig-work" << EOF
[user]
    name = $work_name
    email = $work_email
EOF
ok "Created ~/.gitconfig-work"

work_dir_pattern="${work_dir/#$HOME/~}/"
if grep -q "gitdir:${work_dir_pattern}" "$HOME/.gitconfig" 2>/dev/null; then
  ok "includeIf already configured"
else
  cat >> "$HOME/.gitconfig" << EOF

# Work profile
[includeIf "gitdir:${work_dir_pattern}"]
    path = ~/.gitconfig-work
EOF
  ok "Added includeIf for $work_dir_pattern"
fi
info "Repos in $work_dir/ will auto-use work identity"
echo ""

# ── 5. CLI auth ──────────────────────────────────────────

case "$_provider" in
  github|github-enterprise)
    echo "${bold}  GitHub CLI${reset}"
    read -q "REPLY?  Authenticate gh with $work_host? (y/n) " || true
    echo ""
    if [[ "$REPLY" == "y" ]]; then
      gh auth login --hostname "$work_host"
      ok "Authenticated with gh"
    else
      info "Skipped — run ${dim}gh auth login --hostname $work_host${reset} anytime"
    fi
    ;;
  gitlab)
    echo "${bold}  GitLab CLI${reset}"

    # Install glab if not present
    if ! command -v glab &>/dev/null; then
      info "glab (GitLab CLI) is not installed"
      read -q "REPLY?  Install glab via Homebrew? (y/n) " || true
      echo ""
      if [[ "$REPLY" == "y" ]]; then
        brew install glab 2>/dev/null
        ok "glab installed"
      else
        info "Skipped — install later with: brew install glab"
      fi
    fi

    if command -v glab &>/dev/null; then
      read -q "REPLY?  Authenticate glab with $work_host? (y/n) " || true
      echo ""
      if [[ "$REPLY" == "y" ]]; then
        glab auth login --hostname "$work_host"
        ok "Authenticated with glab"
      else
        info "Skipped — run ${dim}glab auth login${reset} anytime"
      fi
    fi
    ;;
  bitbucket)
    echo "${bold}  Bitbucket${reset}"
    info "No official Bitbucket CLI — SSH key is your auth method"
    info "Add your public key at: https://$work_host/account/settings/ssh-keys/"
    ;;
  *)
    echo "${bold}  CLI Auth${reset}"
    info "No known CLI for $work_host — SSH key is your auth method"
    ;;
esac
echo ""

# ── 6. VS Code alias (optional) ─────────────────────────
echo "${bold}  VS Code${reset}"

read -q "REPLY?  Create VS Code work alias? (y/n) " || true
echo ""
if [[ "$REPLY" == "y" ]]; then
  ask "VS Code profile name [work]: "
  read vscode_profile
  vscode_profile="${vscode_profile:-work}"

  ALIAS_LINE="alias codework=\"code --profile \\\"$vscode_profile\\\"\""

  if grep -q "alias codework=" "$HOME/.zshrc" 2>/dev/null; then
    ok "Alias 'codework' already exists"
  else
    echo "$ALIAS_LINE" >> "$HOME/.zshrc"
    ok "Added alias: codework"
  fi
else
  info "Skipped"
fi

# ── Summary ──────────────────────────────────────────────
echo ""
echo "${green}${bold}  Work profile ready!${reset}"
echo ""
echo "${dim}  $work_name <$work_email>"
echo "  Directory: $work_dir"
echo "  Git host:  $work_host ($_provider)"
echo "  SSH key:   $WORK_KEY${reset}"
echo ""

# Show provider-specific clone instructions
case "$_provider" in
  github)
    echo "  Clone work repos with:"
    echo "  ${bold}git clone git@github.com-work:org/repo.git $work_dir/repo${reset}"
    ;;
  github-enterprise)
    echo "  Clone work repos with:"
    echo "  ${bold}git clone git@$work_host:org/repo.git $work_dir/repo${reset}"
    ;;
  gitlab)
    echo "  Clone work repos with:"
    echo "  ${bold}git clone git@$work_host:org/repo.git $work_dir/repo${reset}"
    ;;
  bitbucket)
    echo "  Clone work repos with:"
    echo "  ${bold}git clone git@$work_host:org/repo.git $work_dir/repo${reset}"
    ;;
  *)
    echo "  Clone work repos with:"
    echo "  ${bold}git clone git@$work_host:org/repo.git $work_dir/repo${reset}"
    ;;
esac
echo ""
echo "${dim}  Restart your terminal: exec zsh${reset}"
echo ""
