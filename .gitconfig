[user]
	email = rflmurad@gmail.com
	name = Rafael Murad
[core]
	excludesfile = ~/.gitignore_global
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[sequence]
	editor = code --wait --reuse-window
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[fetch]
	prune = true
[merge]
	conflictstyle = zdiff3
[diff]
	algorithm = histogram
	colorMoved = default
[rerere]
	enabled = true
[init]
	defaultBranch = main
[alias]
	fresh-branch = "!f() { git checkout main && git pull origin main && git checkout -b \"$1\"; }; f"
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# Work profile override (added by setup-work-profile.sh):
# [includeIf "gitdir:~/work/"]
#     path = ~/.gitconfig-work
